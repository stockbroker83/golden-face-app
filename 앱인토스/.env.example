VITE_ANTHROPIC_API_KEY=your_claude_api_key_here

# Toss Payments (client)
VITE_TOSS_CLIENT_KEY=your_toss_client_key

# Payment confirmation endpoint (same-domain default: /api/toss/confirm)
VITE_TOSS_CONFIRM_API_URL=/api/toss/confirm

# Server-only keys (do NOT prefix with VITE)
TOSS_SECRET_KEY=your_toss_secret_key
# Optional: keep if you validate webhook signature in backend
TOSS_SECURITY_KEY=your_toss_security_key
